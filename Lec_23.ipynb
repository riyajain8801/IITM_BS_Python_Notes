   "source": [
    "# Finding a factorial of a number\n",
    "\n",
    "print(\"enter a number: \")\n",
    "n = int(input())\n",
    "print(n)\n",
    "\n",
    "i = 1\n",
    "a = 1 \n",
    "while (i<=n):\n",
    "  a = a*i\n",
    "  i = i+1\n",
    "print(\"factorial is \", a)\n"
   ]
  }
